{
   "id":null,
   "uid":null,
   "title":"ECS Monitoring Dashboard",
   "tags":[
      "ecs",
      "prometheus"
   ],
   "timezone":"browser",
   "schemaVersion":38,
   "version":1,
   "refresh":"10s",
   "panels":[
      {
         "type":"stat",
         "title":"Service Health (UP)",
         "gridPos":{
            "x":0,
            "y":0,
            "w":6,
            "h":4
         },
         "targets":[
            {
               "expr":"up{job=\"ecs-tasks\"}",
               "refId":"A"
            }
         ]
      },
      {
         "type":"stat",
         "title":"Total Instances",
         "gridPos":{
            "x":6,
            "y":0,
            "w":6,
            "h":4
         },
         "targets":[
            {
               "expr":"count(up{job=\"ecs-tasks\"})",
               "refId":"A"
            }
         ]
      },
      {
         "type":"stat",
         "title":"Down Instances",
         "gridPos":{
            "x":12,
            "y":0,
            "w":6,
            "h":4
         },
         "targets":[
            {
               "expr":"count(up{job=\"ecs-tasks\"} == 0)",
               "refId":"A"
            }
         ]
      },
      {
         "type":"timeseries",
         "title":"CPU Usage",
         "gridPos":{
            "x":0,
            "y":4,
            "w":12,
            "h":8
         },
         "targets":[
            {
               "expr":"rate(process_cpu_user_seconds_total{job=\"ecs-tasks\"}[1m])",
               "legendFormat":"{{instance}}",
               "refId":"A"
            }
         ]
      },
      {
         "type":"timeseries",
         "title":"Memory Usage",
         "gridPos":{
            "x":12,
            "y":4,
            "w":12,
            "h":8
         },
         "targets":[
            {
               "expr":"process_resident_memory_bytes{job=\"ecs-tasks\"}",
               "legendFormat":"{{instance}}",
               "refId":"A"
            }
         ],
         "fieldConfig":{
            "defaults":{
               "unit":"bytes"
            },
            "overrides":[
               
            ]
         }
      },
      {
         "type":"timeseries",
         "title":"Event Loop Lag",
         "gridPos":{
            "x":0,
            "y":12,
            "w":12,
            "h":8
         },
         "targets":[
            {
               "expr":"nodejs_eventloop_lag_seconds{job=\"ecs-tasks\"}",
               "legendFormat":"{{instance}}",
               "refId":"A"
            }
         ]
      },
      {
         "type":"timeseries",
         "title":"GC Duration",
         "gridPos":{
            "x":12,
            "y":12,
            "w":12,
            "h":8
         },
         "targets":[
            {
               "expr":"rate(nodejs_gc_duration_seconds_sum{job=\"ecs-tasks\"}[1m])",
               "legendFormat":"{{instance}}",
               "refId":"A"
            }
         ]
      },
      {
         "type":"timeseries",
         "title":"Scrape Samples",
         "gridPos":{
            "x":0,
            "y":20,
            "w":12,
            "h":8
         },
         "targets":[
            {
               "expr":"scrape_samples_scraped{job=\"ecs-tasks\"}",
               "legendFormat":"{{instance}}",
               "refId":"A"
            }
         ]
      },
      {
         "type":"timeseries",
         "title":"Scrape Duration",
         "gridPos":{
            "x":12,
            "y":20,
            "w":12,
            "h":8
         },
         "targets":[
            {
               "expr":"scrape_duration_seconds{job=\"ecs-tasks\"}",
               "legendFormat":"{{instance}}",
               "refId":"A"
            }
         ]
      }
   ],
   "templating":{
      "list":[
         
      ]
   },
   "annotations":{
      "list":[
         
      ]
   }
}